<?xml version="1.0" encoding="utf-8"?>
<root xmlns:android="http://schemas.android.com/apk/res/android">
	<!-- init section is always evaluated once per architecture -->
	<init>
		<log text="GoogleMobileAds IOS UPL initialization"/>
		<setStringFromProperty result="AppIdIOS" ini="Engine" section="/Script/GoogleMobileAds.GoogleMobileAdsRuntimeSettings" property="AdMobAppID_IOS" default="ca-app-pub-3940256099942544~1458002511"/>
	</init>
	
	<!-- iOS Pod modifications -->
	<iosPodfileUpdates>
		<insert>
			pod 'Google-Mobile-Ads-SDK', '~> 10.0'
		</insert>
	</iosPodfileUpdates>

	<iosPListUpdates>
		<addElements tag="dict">
			<key>GADApplicationIdentifier</key>
			<string>$S(AppIdIOS)</string>
			<key>SKAdNetworkItems</key>
			<array>
				<dict>
					<key>SKAdNetworkIdentifier</key>
					<string>cstr6suwn9.skadnetwork</string>
				</dict>
			</array>
		</addElements>
	</iosPListUpdates>
</root>
